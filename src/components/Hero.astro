---
---

<section class="relative h-screen max-h-[1080px] flex items-center pt-20 overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/hero/hero1.jpg" 
      alt="Consultorio Dra. Salomé Buniva" 
      class="w-full h-full object-cover"
    />
    <!-- Overlay for readability -->
    <div 
      class="absolute inset-0 z-10" 
      style="background: linear-gradient(99.51deg, rgba(30, 20, 10, 0.88) 0%, rgba(30, 20, 10, 0.55) 45%, rgba(160, 120, 80, 0.15) 100%);"
    ></div>
  </div>

  <div class="container mx-auto px-6 relative z-20 grid lg:grid-cols-2 gap-12 items-center">
    <!-- Left Content -->
    <div class="max-w-2xl text-white py-8 lg:py-0">
      <div class="inline-block px-4 py-1.5 bg-[#6B5744]/30 backdrop-blur-md border border-[#DDD0BC]/25 rounded-full mb-6 lg:mb-6">
        <span class="font-dm-sans text-[10px] uppercase tracking-[0.2em] font-light">
          • Excelencia odontológica desde 2006
        </span>
      </div>
      
      <h1 class="font-cormorant text-[38px] md:text-7xl leading-[1.1] mb-6 lg:mb-6">
        Tu primera consulta,<br />
        el comienzo de tu <br />
        <span class="italic text-[#DDD0BC]">mejor sonrisa :)</span>
      </h1>
      
      <p class="font-dm-sans font-light text-white/72 text-[15px] leading-[1.85] tracking-normal mb-8 lg:mb-8 max-w-lg">
        Escribinos por WhatsApp y coordinamos tu turno. Primera consulta con diagnóstico integral — te esperamos en Belgrano o Maschwitz.
      </p>
      
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-6  mb-2 sm:mb-4">
        <a 
          href="https://wa.me/yournumber" 
          class="flex items-center justify-center gap-[10px] bg-[#A07850] text-white w-full sm:w-[252px] h-[46px] px-[28px] py-[14px] rounded-[30px] font-dm-sans text-[14px] font-medium transition-all duration-300 shadow-lg shadow-black/20 active:scale-[0.98] group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="transition-transform duration-300 group-hover:rotate-12">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Escribinos por WhatsApp
        </a>
        <a href="#tratamientos" class="font-dm-sans text-[13px] sm:text-[15px] font-normal text-white/65 hover:text-[#A07850] transition-colors flex items-center gap-2 group sm:pb-[2px]">
          Ver tratamientos 
          <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>
      </div>
      
      <p class="font-dm-sans font-normal text-white/40 text-[11px] leading-none tracking-normal max-w-[400px]">
        La primera consulta requiere un 50% de seña para confirmar el turno.
      </p>
    </div>

    <!-- Right Content (Glass Card) - Hidden on Mobile -->
    <div class="hidden lg:block">
      <div class="bg-black/10 backdrop-blur-xl border border-white/20 rounded-[40px] p-10 max-w-lg ml-auto">
        <h3 class="font-cormorant text-3xl text-white mb-8">
          ¿Por qué elegir a la <span class="italic text-[#DDD0BC]">Dra. Buniva?</span>
        </h3>
        
        <ul class="space-y-4 mb-12">
          {[
            "Diagnóstico integral con escaneo intraoral 3D",
            "Invisalign Provider oficial — ortodoncia fija y funcional",
            "Equipo especializado en cada área",
            "Dos consultorios: Belgrano y Maschwitz"
          ].map((item) => (
            <li class="flex items-start gap-3 text-white/80 font-dm-sans text-[15px]">
              <span class="w-1.5 h-1.5 rounded-full bg-[#DDD0BC] mt-2 shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
        
        <div class="grid grid-cols-3 gap-4 pt-8 border-t border-white/10">
          <div>
            <div class="font-cormorant text-4xl text-white mb-1">18+</div>
            <div class="font-dm-sans text-[10px] text-white/50 uppercase tracking-wider">Años de carrera</div>
          </div>
          <div>
            <div class="font-cormorant text-4xl text-white mb-1">2</div>
            <div class="font-dm-sans text-[10px] text-white/50 uppercase tracking-wider">Consultorios</div>
          </div>
          <div>
            <div class="font-cormorant text-4xl text-white mb-1">3D</div>
            <div class="font-dm-sans text-[10px] text-white/50 uppercase tracking-wider">Diagnóstico digital</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
